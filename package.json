{
  "name": "tangle",
  "version": "0.1.14",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun src/dev.ts",
    "api": "bun --hot src/server.ts",
    "web": "bun --hot src/web/serve.ts",
    "mcp": "bun src/mcp/serve.ts",
    "test": "bun test --concurrency=1 tests/",
    "typecheck": "tsc --noEmit",
    "build": "bun run typecheck",
    "lint": "bunx biome lint src/",
    "format": "bunx biome format src/",
    "check": "bunx biome check src/",
    "lint:fix": "bunx biome lint --write src/",
    "format:fix": "bunx biome format --write src/",
    "check:fix": "bunx biome check --write src/",
    "tidy": "bun run format:fix && bun run lint:fix"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/bun": "latest"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/sanitize-html": "^2.16.1",
    "atlas": "github:wess/atlas#main",
    "isomorphic-git": "^1.27.1",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.3",
    "react": "^19",
    "react-dom": "^19",
    "sanitize-html": "^2.17.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
