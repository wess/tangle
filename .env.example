PORT=3000
WEB_PORT=3001
API_URL=http://localhost:3000
SECRET=change-me-in-production
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tangle

# Where bare git repositories live on disk. Tangle stores every repo as
# `${REPO_DIR}/${owner}/${name}.git`. Repository content is the source
# of truth — keep this on a persistent volume in production. The git
# Smart-HTTP routes (`/<owner>/<repo>.git/...`) read and write directly
# into this directory.
REPO_DIR=./.tangle/repos

# Where user-uploaded blobs (avatars, release assets) live. Either "s3"
# (any S3-compatible bucket — AWS, R2, Spaces, MinIO, RustFS) or "local"
# (disk-backed, single-host). Repository content is NEVER routed
# through this — only attachments. All asset CRUD goes through the API.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.tangle/blobs

# Used only when STORAGE_DRIVER=s3.
S3_ENDPOINT=http://localhost:4000
S3_BUCKET=tangle
S3_REGION=us-east-1
S3_ACCESS_KEY=tangleadmin
S3_SECRET_KEY=tangleadmin

# Public URL where the SPA is served. Used to build links in outgoing
# emails (password reset, invites) and clone hints. Must match what
# users see in their browser.
APP_URL=http://localhost:3001

# Email — Resend (https://resend.com).
# Leave RESEND_API_KEY empty in development; emails will be printed to
# the API console instead of sent. RESEND_FROM must be a verified
# sender on your Resend account, or use "Tangle <onboarding@resend.dev>"
# while you're testing.
RESEND_API_KEY=
RESEND_FROM=Tangle <onboarding@resend.dev>

# Passkeys (WebAuthn). RP_ID is the domain credentials are bound to —
# no port, no protocol. RP_ORIGIN is the full URL the SPA is served
# from. Credentials created on one RP_ID can't be used against another;
# a passkey created on localhost won't work on tangle.io.
RP_ID=localhost
RP_NAME=Tangle
RP_ORIGIN=http://localhost:3001

# Hard cap on a single request body, in bytes. This bounds git push
# pack size, release-asset uploads, and avatar uploads. Default: 1 GiB.
MAX_UPLOAD_BYTES=1073741824

# Comma-separated list of trusted reverse-proxy IPs/CIDRs. X-Forwarded-For
# and X-Real-IP are ONLY honored when the request's socket peer matches
# one of these — otherwise rate-limit buckets and audit logs use the raw
# peer. Leave empty for local dev. IPv4 only.
# When running via compose.yaml, the api container sees traffic from the
# `web` container on the docker bridge — 172.16.0.0/12 covers it.
TRUSTED_PROXIES=

# Compose-only env vars (used by compose.yaml, not the API directly):

# Strong DB password for the local Postgres container.
POSTGRES_PASSWORD=

# Public hostname Caddy serves on. Set to your domain in prod (Caddy
# auto-provisions Let's Encrypt). Use `:80` for plain HTTP local
# testing.
DOMAIN=

# Set to "production" on the server. The API refuses to start with the
# default SECRET when this is anything other than "development".
NODE_ENV=development
